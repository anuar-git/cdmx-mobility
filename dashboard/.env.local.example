# Copy to .env.local and fill in your values.
# NEXT_PUBLIC_ prefix makes the variable available in the browser.

# Cloud Run URL of the pipeline-api service.
# Get it after deploy: gcloud run services describe pipeline-api --region=us-central1 --format="value(status.url)"
NEXT_PUBLIC_API_URL=https://pipeline-api-xxxx-uc.a.run.app

# For local dev against the API without IAM auth, start the API with:
# uvicorn main:app --reload  (from the api/ directory)
# then set: NEXT_PUBLIC_API_URL=http://localhost:8080
