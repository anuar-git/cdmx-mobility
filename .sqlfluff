[sqlfluff]
dialect = bigquery
templater = jinja
max_line_length = 100

# Exclude rules that conflict with the project's column-alignment convention,
# dbt Jinja templating patterns, and pre-existing scaffold files.
exclude_rules = LT01, LT02, LT05, LT13, ST06, ST07, RF04

[sqlfluff:templater:jinja]
apply_dbt_builtins = true

[sqlfluff:templater:jinja:context]
# Dummy values so Jinja rendering doesn't fail during linting
schema = staging_cdmx
