[sqlfluff]
dialect = bigquery
templater = jinja
max_line_length = 100

# Exclude rules that conflict with the project's column-alignment convention,
# dbt Jinja templating patterns, and pre-existing scaffold files.
# ignore = templating, parsing: dbt package macros (dbt_utils.generate_surrogate_key
#   etc.) are not resolvable by sqlfluff without a full dbt compile; suppressing
#   template/parse errors also prevents cascading ST11 false positives.
ignore = templating, parsing
# LT09: single-expression SELECT tests intentionally stay on one line.
# AL01: implicit table aliasing is used consistently in analyses and CTEs.
# AL09: dim_date intentionally passes through column names unchanged.
# RF02: unqualified column refs inside CTEs with a single source are acceptable.
# ST09: join-condition column order follows readability, not rule ST09.
# ST11: cascades from parse failures on dbt_utils macros; excluded as a result.
# CP01: BigQuery ML DDL uses lower-case keywords by convention.
exclude_rules = LT01, LT02, LT05, LT09, LT13, ST06, ST07, ST09, ST11, RF04, RF02, AL01, AL09, CP01

[sqlfluff:templater:jinja]
apply_dbt_builtins = true

[sqlfluff:templater:jinja:context]
# Dummy values so Jinja rendering doesn't fail during linting
schema = staging_cdmx
target = cdmx-mobility-prod
